{
  "name": "api",
  "author": "[fakouyat,nfauconn]",
  "version": "1.0.0",
  "main": "src/index.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only --env-file=.env -r tsconfig-paths/register src/index.ts",
    "test": "jest",
    "test:watch": "jest --runInBand --watch",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "node-pg-migrate up -f migration.config.json",
    "migrate:down": "node-pg-migrate down -f migration.config.json",
    "seed": "ts-node-dev --respawn --transpile-only --env-file=.env -r tsconfig-paths/register src/config/db/seeders/*.ts"
  },
  "devDependencies": {
    "@getbrevo/brevo": "^3.0.1",
    "@jest/globals": "^30.1.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "reflect-metadata": "^0.2.2",
    "superagent": "^10.2.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "keywords": [],
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@faker-js/faker": "^10.1.0",
    "@types/argon2": "^0.14.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express-rate-limit": "^5.1.3",
    "@types/pg": "^8.15.5",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "husky": "^9.1.7",
    "inversify": "^7.10.4",
    "jose": "^6.1.0",
    "multer": "^2.2.0",
    "node-pg-migrate": "^7.6.1",
    "path": "^0.12.7",
    "pg": "^8.16.3",
    "redis": "^5.8.2",
    "resend": "^6.17.2",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.1",
    "tsconfig-paths": "^4.2.0"
  }
}
