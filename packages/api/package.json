  "version": "1.0.0",
  "main": "src/index.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --env-file=.env -r tsconfig-paths/register src/index.ts",
    "test": "jest",
    "test:watch": "jest --runInBand --watch",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "node-pg-migrate up -f migration.config.json",
    "migrate:down": "node-pg-migrate down -f migration.config.json"
  },
  "devDependencies": {
    "@jest/globals": "^30.1.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
