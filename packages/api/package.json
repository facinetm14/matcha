    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "node-pg-migrate": "^7.6.1",
    "nodemon": "^3.1.10",
    "reflect-metadata": "^0.2.2",
    "superagent": "^10.2.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  },
  "keywords": [],
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@types/argon2": "^0.14.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express-rate-limit": "^5.1.3",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "inversify": "^7.9.1",
    "jose": "^6.1.0",
